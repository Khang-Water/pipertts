diff --git a/tests/test_espeak_phonemizer.py b/tests/test_espeak_phonemizer.py
index 57124c7..f12f309 100644
--- a/tests/test_espeak_phonemizer.py
+++ b/tests/test_espeak_phonemizer.py
@@ -1,3 +1,8 @@
+import builtins
+from unittest.mock import patch
+
+import pytest
+
 from piper.phonemize_espeak import EspeakPhonemizer
 
 
@@ -7,3 +12,19 @@ def test_phonemize() -> None:
     assert phonemizer.phonemize("en-us", "test") == [
         ["t", "ˈ", "ɛ", "s", "t"],
     ]
+
+
+def test_missing_espeakbridge_has_actionable_error() -> None:
+    """Missing compiled extension should point to the dev build step."""
+
+    real_import = builtins.__import__
+
+    def _fake_import(name, globals=None, locals=None, fromlist=(), level=0):
+        if (level == 1) and ("espeakbridge" in fromlist):
+            raise ImportError("missing extension")
+
+        return real_import(name, globals, locals, fromlist, level)
+
+    with patch("builtins.__import__", side_effect=_fake_import):
+        with pytest.raises(ImportError, match=r"build_ext --inplace"):
+            EspeakPhonemizer()
