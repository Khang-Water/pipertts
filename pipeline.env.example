# Copy to pipeline.env and edit. Sourced by run_pipeline.sh with `set -a`,
# so every value here is exported to the child scripts too.

# --- Required ---------------------------------------------------------------
# Manifest: one line per utterance, "audio_path|Transcript text"
MANIFEST=/secret/path/manifest.csv
# Base dir for relative audio paths in the manifest ("/" if paths are absolute)
SRC_AUDIO_DIR=/secret/path/audio

# --- Manifest format (defaults: "path|text", no header) -----------------------
# MANIFEST_DELIMITER='|'    # ',' for CSV, '\t' for TSV
# MANIFEST_HAS_HEADER=1     # 1 = skip first line
# PATH_COLUMN=0
# TEXT_COLUMN=1

# --- Training ----------------------------------------------------------------
NUM_GPUS=2
# EXTRA_STEPS = ABSOLUTE training global_step target, counted from 0. The base
# checkpoint is Lightning v1.7 and resets global_step to 0 on load, so this is
# the total number of fine-tune steps, NOT "extra beyond the base". VITS adds 2
# global_steps per batch (G+D optimizers), so 20000 steps with batch 48 / 51
# batches-per-epoch is ~196 epochs. Watch for overfitting on 6.6h of data.
EXTRA_STEPS=20000
BATCH_SIZE=16              # per GPU
NUM_WORKERS=16
PRECISION=bf16-mixed
VALIDATION_SPLIT=0.05
# Keep ALL step checkpoints so you can pick the best by ear before overfitting
# (every 2000 steps -> 10 checkpoints for a 20000-step run, ~280MB each).
CKPT_EVERY_N_STEPS=2000
CKPT_SAVE_TOP_K=-1

# Shared server: pin the GPU index(es) you were assigned (see nvidia-smi),
# otherwise Lightning grabs GPU 0 even if someone else is using it.
# CUDA_VISIBLE_DEVICES=0,1
# Only 1 GPU available? NUM_GPUS=1 and BATCH_SIZE=32 keeps the same
# effective batch (DDP is skipped automatically).

# --- Voice -------------------------------------------------------------------
VOICE_NAME=vi_VN-secret-medium
ESPEAK_VOICE=vi
SAMPLE_RATE=22050
MIN_DURATION_S=0.5
MAX_DURATION_S=30

# --- Behavior ----------------------------------------------------------------
STRICT_PREFLIGHT=1         # fail if GPUs are not A100
SKIP_EXPORT=0              # 1 = stop after training, export manually later
# FORCE_PREPARE=1          # uncomment to rebuild metadata from the manifest
